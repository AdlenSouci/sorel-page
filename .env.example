# ─── Local (.env à la racine de sorel_page) ───
DATABASE_URL="mysql://root@127.0.0.1:3306/sorel_local"
API_PORT=3001
VITE_API_URL=

# ─── Vercel (pas de fichier .env sur le serveur) ───
# Projet Vercel → Settings → Environment Variables → Production
#
# DATABASE_URL
#   Base MySQL de prod (même hôte que sorel-order.fr si les tables y sont).
#   Format : mysql://UTILISATEUR:MOT_DE_PASSE_URL_ENCODE@HOTE:3306/NOM_BASE
#   Ex. mot de passe y!a=b_@DDCYJ → y%21a%3Db_%40DDCYJ
#
# VITE_API_URL
#   Laisser VIDE (les appels vont vers /api/... sur le même domaine Vercel).
