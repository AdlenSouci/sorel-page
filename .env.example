# Connexion MySQL (o2switch) — Prisma utilise DATABASE_URL ou les variables DB_* ci-dessous
DB_CONNECTION=mysql
DB_HOST=
DB_PORT=3306
DB_DATABASE=kera6497_sorel-plastique
DB_USERNAME=
DB_PASSWORD=

# Ou directement (équivalent) :
# DATABASE_URL=mysql://USER:PASS@HOST:3306/kera6497_sorel-plastique

# Local Express (npm run dev:full)
API_PORT=3001

# Optionnel : si les photos en base sont des chemins relatifs (/storage/…)
# VITE_MEDIA_BASE_URL=
