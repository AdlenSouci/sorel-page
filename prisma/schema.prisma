generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "mysql"
  url      = env("DATABASE_URL")
}

model Category {
  id        Int         @id @default(autoincrement()) @db.UnsignedInt
  nom       String      @db.VarChar(100)
  slug      String      @unique @db.VarChar(100)
  ordre     Int         @default(0)
  catalogue Catalogue[]

  @@map("categories")
}

model Catalogue {
  id          Int      @id @default(autoincrement()) @db.UnsignedInt
  categorieId Int      @map("categorie_id") @db.UnsignedInt
  codeArticle String?  @map("code_article") @db.VarChar(50)
  libelle     String   @db.VarChar(255)
  variante    String?  @db.VarChar(100)
  photo       String?  @db.VarChar(255)
  categorie   Category @relation(fields: [categorieId], references: [id])

  @@index([categorieId], map: "idx_catalogue_categorie")
  @@map("catalogue")
}
