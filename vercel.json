{
  "buildCommand": "prisma generate && npm run build",
  "outputDirectory": "dist",
  "rewrites": [
    {
      "source": "/api/categories/:slug/items",
      "destination": "/api/items?slug=:slug"
    },
    {
      "source": "/api/catalog-filters",
      "destination": "/api/categories?view=filters"
    },
    {
      "source": "/api/products",
      "destination": "/api/categories?view=products"
    },
    {
      "source": "/((?!api/).*)",
      "destination": "/index.html"
    }
  ]
}
